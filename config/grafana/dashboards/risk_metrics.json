{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus 数据源",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.5.3" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "火种系统实时风险监控仪表板 v7.0.0。覆盖权益、杠杆、VaR、ES、波动率、敞口使用率、回撤、收益率、保证金、订单延迟、资金费率、连续亏损等核心风控指标，内置告警规则。负责人：quant-team@spark.example.com。生产环境只读。",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "doc",
      "title": "风险预算设计文档",
      "tooltip": "查看 RiskBudget 模块详细说明",
      "type": "link",
      "url": "/docs/risk_budget.md"
    },
    {
      "asDropdown": false,
      "icon": "dashboard",
      "title": "策略引擎仪表板",
      "tooltip": "跳转到策略引擎监控",
      "type": "link",
      "url": "/d/spark-engine-overview"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50000 },
              { "color": "blue", "value": 100000 }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "risk_budget_equity",
          "refId": "A",
          "step": "60"
        }
      ],
      "title": "当前权益 (USDT)",
      "type": "stat",
      "description": "账户总权益。低于 50k 红色，50k-100k 橙色，高于 100k 蓝色。",
      "alert": {
        "alertRuleTags": {},
        "conditions": [
          {
            "evaluator": { "params": [50000], "type": "lt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "keep_state",
        "for": "5m",
        "frequency": "1m",
        "handler": 0,
        "message": "权益低于 50,000 USDT",
        "name": "权益过低告警",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "risk_budget_leverage",
          "refId": "A",
          "step": "60"
        }
      ],
      "title": "当前杠杆",
      "type": "stat",
      "description": "总敞口/权益。超过 5 倍红色，3-5 倍橙色。",
      "alert": {
        "alertRuleTags": {},
        "conditions": [
          {
            "evaluator": { "params": [5], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "keep_state",
        "for": "2m",
        "frequency": "1m",
        "handler": 0,
        "message": "杠杆超过 5 倍",
        "name": "杠杆超限告警",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 0.015 },
              { "color": "red", "value": 0.02 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "risk_budget_es_ratio",
          "refId": "A",
          "step": "60"
        }
      ],
      "title": "ES / 权益",
      "type": "stat",
      "description": "Expected Shortfall 占权益比例。超过 2% 红色。",
      "alert": {
        "alertRuleTags": {},
        "conditions": [
          {
            "evaluator": { "params": [0.02], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "keep_state",
        "for": "5m",
        "frequency": "1m",
        "handler": 0,
        "message": "ES/权益超过 2%",
        "name": "ES超限告警",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "risk_budget_equity - risk_budget_equity offset 1d",
          "refId": "A",
          "step": "300"
        }
      ],
      "title": "当日盈亏 (USDT)",
      "type": "stat",
      "description": "过去24小时权益变化量。亏损红色，盈利绿色。"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "(max_over_time(risk_budget_equity[30d]) - risk_budget_equity) / max_over_time(risk_budget_equity[30d])",
          "refId": "A",
          "step": "300"
        }
      ],
      "title": "30日最大回撤",
      "type": "stat",
      "description": "橙色>5%，红色>10%",
      "alert": {
        "alertRuleTags": {},
        "conditions": [
          {
            "evaluator": { "params": [0.1], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "keep_state",
        "for": "5m",
        "frequency": "1m",
        "handler": 0,
        "message": "30日最大回撤超过 10%",
        "name": "回撤超限告警",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "敞口 (USDT)"
          },
          "unit": "currencyUSD"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "总敞口" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "最大允许敞口" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 3 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_total_exposure", "refId": "A", "step": "120" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_max_exposure", "refId": "B", "step": "120" }
      ],
      "title": "总敞口 vs 最大允许敞口",
      "type": "timeseries",
      "description": "橙色：总敞口；蓝色：最大允许敞口。当橙色超过蓝色时风险超限"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "波动率"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 3 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_volatility", "refId": "A", "step": "120" }
      ],
      "title": "组合年化波动率",
      "type": "timeseries",
      "description": "年化波动率。>30%橙色，>50%红色",
      "alert": {
        "alertRuleTags": {},
        "conditions": [
          {
            "evaluator": { "params": [0.5], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "keep_state",
        "for": "5m",
        "frequency": "1m",
        "handler": 0,
        "message": "年化波动率超过 50%",
        "name": "波动率异常告警",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "比率"
          },
          "unit": "percentunit"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "VaR 95%" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "ES 95%" }, "properties": [{ "id": "color", "value": { "fixedColor": "red" } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 13 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_var_95", "refId": "A", "step": "120" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_es_95", "refId": "B", "step": "120" }
      ],
      "title": "VaR 95% 与 ES 95%",
      "type": "timeseries",
      "description": "VaR（橙色）和 Expected Shortfall（红色）"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "权益 (USDT)"
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 13 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_equity", "refId": "A", "step": "300" }
      ],
      "title": "权益曲线",
      "type": "timeseries",
      "description": "账户权益历史走势"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "id": 10,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_total_exposure / risk_budget_max_exposure", "refId": "A", "step": "120" }
      ],
      "title": "敞口使用率",
      "type": "gauge",
      "description": ">70%橙色，>90%红色"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "risk_budget_leverage", "refId": "A", "step": "120" }
      ],
      "title": "杠杆仪表",
      "type": "gauge",
      "description": "红色区域 >5 倍"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": -0.05 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 31 },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "(risk_budget_equity - risk_budget_equity offset 1d) / (risk_budget_equity offset 1d)",
          "refId": "A",
          "step": "300"
        }
      ],
      "title": "24小时收益率",
      "type": "stat",
      "description": "亏损超过 5% 红色，否则绿色"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.0001 },
              { "color": "red", "value": 0.001 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 31 },
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, rate(order_latency_seconds_bucket[5m]))",
          "refId": "A",
          "step": "60"
        }
      ],
      "title": "订单延迟 P95",
      "type": "stat",
      "description": "95% 订单延迟 (秒)。橙色 >0.1ms，红色 >1ms"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 37 },
      "id": 14,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "margin_usage_ratio * 100",
          "refId": "A",
          "step": "60"
        }
      ],
      "title": "保证金使用率 (%)",
      "type": "stat",
      "description": "已用保证金/总保证金。红色 > 80%",
      "alert": {
        "alertRuleTags": {},
        "conditions": [
          {
            "evaluator": { "params": [80], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A", "5m", "now"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "executionErrorState": "keep_state",
        "for": "2m",
        "frequency": "1m",
        "handler": 0,
        "message": "保证金使用率超过 80%",
        "name": "保证金过高告警",
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "axisLabel": "费率"
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 37 },
      "id": 15,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "funding_fee_rate",
          "refId": "A",
          "step": "60"
        }
      ],
      "title": "资金费率",
      "type": "timeseries",
      "description": "当前资金费率（极端费率可能导致巨额费用）"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
