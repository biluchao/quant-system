# =============================================================================
# 火种 (Spark) 量化交易系统 - 环境变量配置模板
# =============================================================================
# 版本: 1.0.0 | 适用于 v3.0.0 架构
# 用途: 开发与测试环境参考，生产环境请使用 HashiCorp Vault 注入密钥
# 警告: 此文件包含敏感信息示例，切勿提交到版本控制系统 (Git)
#       生产部署前请确保所有密码/密钥已替换为强随机值并通过 Vault 管理
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 交易所 API 配置
# -----------------------------------------------------------------------------
# 币安合约 API 密钥 (如使用 Vault 管理则可留空，仅本地开发直接使用)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# REST 基础 URL (主网/测试网)
BINANCE_REST_URL=https://fapi.binance.com
# WebSocket 基础 URL
BINANCE_WS_URL=wss://fstream.binance.com/ws

# 交易所请求超时 (秒)
EXCHANGE_REQUEST_TIMEOUT=10

# -----------------------------------------------------------------------------
# 2. HashiCorp Vault (生产环境密钥管理)
# -----------------------------------------------------------------------------
# Vault 服务地址 (开发环境可用 vault dev 模式)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=

# 密钥存储路径前缀 (Vault KV v2)
VAULT_SECRET_PATH=secret/spark

# Vault 角色 ID (AppRole 认证，可选)
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# -----------------------------------------------------------------------------
# 3. 系统标识与节点信息
# -----------------------------------------------------------------------------
# 节点唯一标识 (用于幂等键生成，默认自动使用主机名)
SPARK_MACHINE_ID=
# 部署环境名称 (dev/staging/prod)
DEPLOY_ENV=dev
# 系统时区 (默认 UTC)
TZ=UTC

# -----------------------------------------------------------------------------
# 4. 日志与审计
# -----------------------------------------------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 审计日志 HMAC 签名密钥 (必须为随机强密码，生产环境从 Vault 读取)
SPARK_AUDIT_HMAC_KEY=change-me-to-a-random-string-at-least-32-chars

# 审计日志本地保留天数
AUDIT_RETENTION_DAYS=30

# 审计日志远程同步目标 (S3 桶 URL，可选)
AUDIT_S3_BUCKET=
AUDIT_S3_PREFIX=prod/

# -----------------------------------------------------------------------------
# 5. 监控与可观测性
# -----------------------------------------------------------------------------
# Prometheus 指标暴露端口 (0 表示禁用)
PROMETHEUS_PORT=9090

# 是否启用详细性能指标 (1/0)
PERF_METRICS_ENABLED=0

# 健康检查端点认证令牌 (可选)
HEALTH_CHECK_TOKEN=

# -----------------------------------------------------------------------------
# 6. Redis 配置 (热备状态缓存 / 事件总线后端)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis 连接超时 (秒)
REDIS_TIMEOUT=3

# Redis 键前缀 (多实例隔离)
REDIS_KEY_PREFIX=spark:

# -----------------------------------------------------------------------------
# 7. SQLite 配置 (本地持久化)
# -----------------------------------------------------------------------------
# 数据库文件路径
SQLITE_PATH=data/spark.db

# 数据库连接池大小 (SQLite 通常单连接，预留)
SQLITE_POOL_SIZE=1

# -----------------------------------------------------------------------------
# 8. 策略与风控参数 (可被 config/*.yaml 覆盖)
# -----------------------------------------------------------------------------
# 默认交易品种 (逗号分隔)
TRADING_SYMBOLS=BTCUSDT

# 初始权益 (开发/回测使用)
INITIAL_CAPITAL=100000

# 最大杠杆倍数
MAX_LEVERAGE=5.0

# 日内最大亏损比例 (权益百分比，触及即熔断)
DAILY_LOSS_LIMIT_PCT=0.08

# 连续亏损次数熔断
MAX_CONSECUTIVE_LOSSES=5

# -----------------------------------------------------------------------------
# 9. 订单执行与费率
# -----------------------------------------------------------------------------
# 默认执行策略 (adaptive / twap / passive)
DEFAULT_EXECUTION_STRATEGY=adaptive

# 订单频率限制 (每秒最大订单数)
MAX_ORDERS_PER_SEC=8

# 资金费率检查间隔 (分钟)
FUNDING_FEE_CHECK_INTERVAL_MINUTES=15

# -----------------------------------------------------------------------------
# 10. 性能与资源限制
# -----------------------------------------------------------------------------
# 事件总线最大队列长度
EVENT_BUS_MAX_QUEUE=10000

# 策略引擎计算线程数 (0 表示自动)
STRATEGY_WORKER_THREADS=0

# 内存使用率告警阈值 (百分比)
MEMORY_ALERT_THRESHOLD_PCT=85

# -----------------------------------------------------------------------------
# 11. 安全与加密
# -----------------------------------------------------------------------------
# 状态恢复数据签名密钥 (必须与生产环境一致)
SPARK_STATE_SIGNING_KEY=change-me-to-another-random-string

# 内部通信 mTLS 证书路径 (生产环境启用)
MTLS_CA_CERT=
MTLS_CLIENT_CERT=
MTLS_CLIENT_KEY=

# -----------------------------------------------------------------------------
# 12. 通知与告警
# -----------------------------------------------------------------------------
# 告警 Webhook URL (如 Slack / 企业微信 / PagerDuty)
ALERT_WEBHOOK_URL=

# 邮件告警 (SMTP)
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# -----------------------------------------------------------------------------
# 13. 数据归档与清理
# -----------------------------------------------------------------------------
# 行情数据本地保留天数
MARKET_DATA_RETENTION_DAYS=30

# 自动归档到 S3 的开关 (1/0)
DATA_ARCHIVE_ENABLED=0
DATA_ARCHIVE_S3_BUCKET=
DATA_ARCHIVE_S3_PREFIX=archive/

# -----------------------------------------------------------------------------
# 14. 开发/调试专用
# -----------------------------------------------------------------------------
# 是否启用回测模拟模式 (1/0)
BACKTEST_MODE=0

# 是否打印详细的决策过程日志 (1/0)
VERBOSE_DECISION_LOG=0

# 是否允许覆盖生产安全检查 (仅限开发环境)
UNSAFE_MODE=0
